# NTK LLM Configuration
#
# NTK uses two tiers of models:
# - Planner: strong model for reasoning (high-info agent)
# - Compressor: cheap model for Scout/Summarizer/Executor/Verifier (low-info agents)
#
# Use multi-endpoint format (API_ENDPOINT_N_*) for automatic failover.

# ─── Multi-endpoint (recommended) ─────────────
# API_ENDPOINT_1_KEY=sk-your-key
# API_ENDPOINT_1_URL=https://your-api.com/v1
# API_ENDPOINT_1_NAME=primary
#
# API_ENDPOINT_2_KEY=sk-backup-key
# API_ENDPOINT_2_URL=https://backup-api.com/v1
# API_ENDPOINT_2_NAME=backup

# ─── Model config ─────────────────────────────
# Planner uses the strong model (best reasoning)
PLANNER_MODEL=gpt-4o
# All other agents use the cheap model (focused tasks)
COMPRESSOR_MODEL=gpt-4o-mini

# If you want a single model for everything, just set MODEL:
# MODEL=gpt-4o

# ─── Debug ──────────────────────────────────────
DEBUG=false
